# Backend
PROOF_BACKEND_HOST=127.0.0.1
PROOF_BACKEND_PORT=8000
PROOF_BACKEND_RELOAD=false
PROOF_LOG_LEVEL=INFO

# Audio ingestion
PROOF_AUDIO_DUMP_DIR=.data/audio
# Set to 0 to disable local debug WAV capture. Phase 1 verification uses 30 seconds.
PROOF_AUDIO_DUMP_SECONDS=30
PROOF_AUDIO_QUEUE_MAX=512
PROOF_VAD_PROVIDER=rms

# Live STT worker. Disabled by default so backend startup never loads a model unexpectedly.
PROOF_STT_ENABLED=false
PROOF_STT_PROVIDER=mlx_whisper
PROOF_STT_MODEL=mlx-community/whisper-large-v3-turbo
PROOF_STT_LANGUAGE=en
PROOF_STT_QUEUE_MAX=32
PROOF_STT_BUFFER_HISTORY_MS=120000
PROOF_STT_PRE_ROLL_MS=150
PROOF_STT_POST_ROLL_MS=250

# Telemetry
# Captures per-session metadata and chunk-level health metrics unless the extension disables it.
PROOF_TELEMETRY_ENABLED=true
PROOF_TELEMETRY_DIR=.data/telemetry

# Extension
PROOF_EXTENSION_WS_URL=ws://127.0.0.1:8000/ws/audio

# Future Phase 2/3 cloud fallbacks. Leave empty for local-only mode.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CARTESIA_API_KEY=
